{
  "name": "craftpg-api",
  "version": "1",
  "items": [
    {
      "name": "Health",
      "items": [
        {
          "name": "Health (Actuator)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health"
          }
        }
      ]
    },
    {
      "name": "Campaigns",
      "items": [
        {
          "name": "List",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/campaigns",
            "headers": [{ "name": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/campaigns",
            "headers": [
              { "name": "Authorization", "value": "Bearer {{token}}" },
              { "name": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"A Sombra de Ravenfall\",\n  \"description\": \"Campanha medieval focada em investigação e horror\",\n  \"frequency\": \"WEEKLY\",\n  \"status\": \"ACTIVE\",\n  \"progressPercent\": 15\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/campaigns/{{campaignId}}",
            "headers": [{ "name": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/campaigns/{{campaignId}}",
            "headers": [
              { "name": "Authorization", "value": "Bearer {{token}}" },
              { "name": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"A Sombra de Ravenfall - Ato II\",\n  \"description\": \"Grupo avançou para as catacumbas da cidade\",\n  \"frequency\": \"WEEKLY\",\n  \"status\": \"ACTIVE\",\n  \"progressPercent\": 45\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/campaigns/{{campaignId}}",
            "headers": [{ "name": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Finish",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/campaigns/{{campaignId}}/finish",
            "headers": [{ "name": "Authorization", "value": "Bearer {{token}}" }]
