meta {
  name: Login - Password Grant
  type: http
  seq: 1
}

post {
  url: {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
  body: text
  auth: none
}

headers {
  Content-Type: application/x-www-form-urlencoded
}

body:text {
  grant_type=password&client_id={{clientId}}&username={{defaultUserEmail}}&password={{defaultUserPassword}}&scope=openid%20profile%20email
}
