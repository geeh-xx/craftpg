meta {
  name: Refresh Token
  type: http
  seq: 2
}

post {
  url: {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
  body: text
  auth: none
}

headers {
  Content-Type: application/x-www-form-urlencoded
}

body:text {
  grant_type=refresh_token&client_id={{clientId}}&refresh_token={{refreshToken}}
}
